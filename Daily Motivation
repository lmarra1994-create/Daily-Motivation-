<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Spark | Motivation</title>
    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            text-align: center;
        }
        .container {
            max-width: 600px;
            padding: 2rem;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        h1 { font-size: 1.2rem; text-transform: uppercase; letter-spacing: 2px; opacity: 0.8; }
        #quote { font-size: 2rem; font-style: italic; margin: 20px 0; line-height: 1.4; }
        #author { font-weight: bold; font-size: 1.1rem; opacity: 0.9; }
        button {
            margin-top: 30px;
            padding: 12px 25px;
            border: none;
            border-radius: 30px;
            background: white;
            color: #764ba2;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s;
        }
        button:hover { transform: scale(1.05); }
    </style>
</head>
<body>

    <div class="container">
        <h1>Your Daily Spark</h1>
        <div id="quote">"Loading inspiration..."</div>
        <div id="author"></div>
        <button onclick="getQuote()">New Quote</button>
    </div>

    <script>
        async function getQuote() {
            const quoteText = document.getElementById('quote');
            const authorText = document.getElementById('author');
            
            try {
                // Using a public API to fetch random quotes
                const response = await fetch('https://api.quotable.io/random');
                const data = await response.json();
                
                quoteText.innerText = `"${data.content}"`;
                authorText.innerText = `— ${data.author}`;
            } catch (error) {
                quoteText.innerText = "Focus on the step in front of you, not the whole staircase.";
                authorText.innerText = "— Unknown";
            }
        }

        // Run on load
        getQuote();
    </script>
</body>
</html>
